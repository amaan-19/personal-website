---
const { pageTitle, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Amaan Khan</title>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-CK7KJ4R9TQ');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/washu_logo.png">
</head>
<body>
  <!-- Sticky Navigation -->
  <nav class="nav">
    <div class="nav-container">
      <div class="nav-links">
        <a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`}>Home</a>
        <a href="/blog" class={`nav-link ${currentPath.startsWith('/blog') ? 'active' : ''}`}>Blog</a>
      </div>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
        <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </nav>

  <div class="layout">
    <!-- Sticky Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-content">
        <div class="profile-section">
          <img src="/profile.jpeg" alt="Amaan Khan" class="profile-image">
          <h1 class="profile-name">Amaan Khan</h1>
          <p class="profile-title">Graduate Student & Researcher</p>
        </div>

        <div class="social-links">
          <a href="mailto:amaan@wustl.edu" class="social-link" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </a>
          <a href="https://linkedin.com/in/amaankhan19" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
          <a href="https://github.com/amaan-19" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="/cv.pdf" class="social-link cv-link" aria-label="CV" download>
            <span class="cv-text">CV</span>
          </a>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <slot />
    </main>
  </div>

  <script is:inline>
    // Dark mode functionality - must run before page renders
    (function() {
      const savedTheme = localStorage.getItem('theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = savedTheme || (systemPrefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>

  <script>
    // Dark mode toggle
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;

    function setTheme(theme: string) {
      html.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    }

    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const currentTheme = html.getAttribute('data-theme') || 'light';
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        setTheme(newTheme);
      });
    }

    // Active navigation highlighting (only for hash-based navigation on home page)
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');
    const currentPath = window.location.pathname;

  </script>
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Light mode colors */
    --color-bg: #ffffff;
    --color-text: #1a1a1a;
    --color-text-muted: #6b7280;
    --color-border: #e5e7eb;
    --color-accent: #636B2F;
    --color-accent-hover: #7a8539;
    --color-surface: #f9fafb;
    --color-sidebar: #F2F0EF;
    --color-nav-bg: rgba(255, 255, 255, 0.95);
    --font: 'Space Mono', monospace;
    --nav-height: 70px;
    --sidebar-width: 320px;
  }

  [data-theme="dark"] {
    /* Dark mode colors */
    --color-bg: #0f0f0f;
    --color-text: #e5e5e5;
    --color-text-muted: #a1a1a1;
    --color-border: #2a2a2a;
    --color-accent: #8a9a4a;
    --color-accent-hover: #9fb058;
    --color-surface: #1a1a1a;
    --color-sidebar: #161616;
    --color-nav-bg: rgba(15, 15, 15, 0.95);
  }

  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    font-family: var(--font);
    line-height: 1.6;
    color: var(--color-text);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: var(--sidebar-width);
    right: 0;
    height: var(--nav-height);
    background: var(--color-nav-bg);
    backdrop-filter: blur(10px);
    z-index: 100;
  }

  .nav-container {
    max-width: 100%;
    height: 100%;
    padding: 0 2rem;
    padding-left: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -1.45rem;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
  }

  .theme-toggle {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
    border-radius: 0.25rem;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
  }

  .sun-icon,
  .moon-icon {
    width: 20px;
    height: 20px;
  }

  [data-theme="light"] .moon-icon {
    display: none;
  }

  [data-theme="dark"] .sun-icon {
    display: none;
  }

  /* Layout */
  .layout {
    height: 100vh;
    overflow: hidden;
  }

  /* Sidebar - extends to top of page */
  .sidebar {
    position: fixed;
    left: 0;
    top: 0; /* Starts at very top */
    width: var(--sidebar-width);
    height: 100vh; /* Full height */
    background: var(--color-sidebar);
    overflow-y: auto;
    z-index: 50; /* Behind nav */
  }

  .sidebar-content {
    padding-top: var(--nav-height); /* Add padding for nav */
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .profile-section {
    text-align: center;
    padding-top: 2rem;
  }

  .profile-image {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.5rem;
    border: 2px solid var(--color-accent);
  }

  .profile-name {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .profile-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .profile-subtitle {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .bio-section {
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .bio-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    text-align: center;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .social-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .cv-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .quick-links {
    padding-top: 1rem;
  }

  .quick-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    transition: all 0.2s ease;
  }

  .quick-link:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  /* Main Content */
  .main-content {
    margin-left: var(--sidebar-width);
    margin-top: var(--nav-height);
    padding-left: 2rem;  /* Match nav-container padding-left */
    padding-right: 3rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
    box-sizing: border-box;
  }

  .home {
    max-width: 900px;
  }

  /* Typography */
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    scroll-margin-top: calc(var(--nav-height) + 2rem);
  }

  h3 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  p {
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }

  pre {
    background: var(--color-surface);
    padding: 1.5rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
  }

  pre code {
    background: none;
    padding: 0;
    border: none;
  }

  ul, ol {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }

  li {
    margin-bottom: 0.5rem;
  }

  /* Sections */
  section {
    margin-bottom: 3rem;
    scroll-margin-top: calc(var(--nav-height) + 2rem);
  }

  /* Updates Section */
  .updates-list {
    display: grid;
    gap: 0;
    border-left: 2px solid var(--color-accent);
    padding-left: 0;
    max-width: 900px;
    max-height: 240px;
    overflow-y: auto;
  }

  .update-item {
    padding: 1rem 0 1rem 1.5rem;
    position: relative;
  }

  .update-item:last-child {
    border-bottom: none;
  }

  .update-date {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .update-text {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9375rem;
  }

  .lead {
    margin-bottom: 3rem;
  }

  /* Mobile Responsive */
  @media (max-width: 1024px) {
    :root {
      --sidebar-width: 280px;
    }

    .main-content {
      padding: 2rem;
    }
  }

  @media (max-width: 768px) {
    .nav {
      left: 0; /* Full width on mobile */
    }

    .nav-container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .logo {
      font-size: 1rem;
    }

    .layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .profile-section {
      margin-top: 2rem;
    }

    .sidebar-content {
      padding: 2rem 1.5rem;
    }

    .profile-image {
      width: 120px;
      height: 120px;
    }

    .main-content {
      margin-left: 0;
      margin-top: var(--nav-height);
      padding: 2rem 1.5rem;
    }

    h1 {
      font-size: 2rem;
    }

    h2 {
      font-size: 1.5rem;
      margin-top: 3rem;
    }
  }
</style>

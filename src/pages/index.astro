---
import SinglePageLayout from '../layouts/BaseLayout.astro';
---

<SinglePageLayout pageTitle="Home">
  <!-- About Section -->
  <section class="home">
    <p class="lead">
      I'm a master's student in cybersecurity engineering at Washington 
      University in St. Louis. Previously, I completed my BS in Computer Science,
      also at WashU. As a researcher, I'm broadly interested in security for 
      cyber-physical systems, adversarial machine learning, and trustworthy AI.
    </p>
  </section>

  <!-- Updates Section -->
  <section id="updates">
    <h3>Updates</h3>
    
    <div class="updates-list">
      <div class="update-item">
        <time class="update-date">Jan 20, 2026</time>
        <p class="update-text">Joined <a href="https://husseinsibai.web.illinois.edu/index.html" target="_blank">Prof. Sibai's</a> Autonomous Systems lab!</p>
      </div>

      <div class="update-item">
        <time class="update-date">Jan 7, 2026</time>
        <p class="update-text">Started my blog.</p>
      </div>

      <div class="update-item">
        <time class="update-date">Dec 22, 2025</time>
        <p class="update-text">Launched my new academic website.</p>
      </div>

      <div class="update-item">
        <time class="update-date">Dec 13, 2025</time>
        <p class="update-text">Completed undergrad!</p>
      </div>
    </div>
  </section>
</SinglePageLayout>
